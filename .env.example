# ─────────────────────────────────────────────────────────────────────────────
# Allo Inventory — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase / Neon / Railway) ────────────────────────────────────
# Get this from your Supabase project → Settings → Database → Connection string
# Or from Neon → Dashboard → Connection details → Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1"

# Supabase also requires a direct (non-pooled) URL for migrations:
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# Then add to schema.prisma: directUrl = env("DIRECT_URL")

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Get these from Upstash Console → your database → REST API section
UPSTASH_REDIS_REST_URL="https://YOUR-REDIS.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR-TOKEN-HERE"

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
